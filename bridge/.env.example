# MeetingCopilot NotebookLM Bridge Configuration
PORT=3210
MODE=mock
GOOGLE_EMAIL=your@gmail.com
DEFAULT_NOTEBOOK_ID=your_notebook_id
LOG_LEVEL=info

# v4.3 Security: Shared secret for bridge authentication
# If not set, a random token is generated on each startup
# Copy the token shown at startup and set it here for persistence
BRIDGE_SECRET=your_shared_secret_here
