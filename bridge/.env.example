# NotebookLM Bridge Configuration
# Copy to .env and fill in your values

# Bridge server port
PORT=3210

# Mode: 'puppeteer' (browser automation) or 'mock' (dev/testing)
MODE=mock

# Google account credentials (for Puppeteer mode)
GOOGLE_EMAIL=your-email@gmail.com
# Auth is handled via saved browser session, not password

# NotebookLM settings
DEFAULT_NOTEBOOK_ID=

# Logging
LOG_LEVEL=info
